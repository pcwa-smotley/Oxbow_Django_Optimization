# ABAY Optimization Dashboard — Environment Variables
# Copy this to .env in the project root and fill in your values.
# NEVER commit .env to git.

# Django
DJANGO_SECRET_KEY='replace-with-output-of: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"'
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS='your-domain.com,your-server-ip'

# Site URL (used in alert email links)
SITE_URL='https://your-domain.com'

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Sentry (error tracking)
SENTRY_DSN=''
